---
interface Props {
  showDownload?: boolean;
}

const { showDownload = true } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-40 w-full border-b border-[var(--border)] bg-[var(--background)]/95 backdrop-blur">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <a href={base} class="flex items-center gap-2 font-semibold text-[var(--foreground)]">
        <img src={`${base}favicon.png`} alt="" width="28" height="28" aria-hidden="true" />
        <span>ClipJot</span>
      </a>

      <nav class="hidden sm:flex items-center gap-6 text-sm text-[var(--muted-foreground)]">
        <a href={`${base}#how-it-works`} class="hover:text-[var(--foreground)] transition-colors">How it works</a>
        <a href={`${base}#features`} class="hover:text-[var(--foreground)] transition-colors">Features</a>
      </nav>

      {showDownload && (
        <a
          href={`${base}#download`}
          class="inline-flex h-9 items-center justify-center rounded-md bg-[var(--primary)] px-4 py-2 text-sm font-medium text-[var(--primary-foreground)] hover:bg-(--primary-hover) transition-colors"
        >
          Download
        </a>
      )}
    </div>
  </div>
</header>
