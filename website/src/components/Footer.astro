---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border)] bg-[var(--surface-panel)] py-10">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <!-- Brand -->
      <div class="flex items-center gap-2 text-sm font-medium text-[var(--foreground)]">
        <img src={`${base}favicon.png`} alt="" width="20" height="20" aria-hidden="true" />
        ClipJot
      </div>

      <!-- Legal links -->
      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-[var(--muted-foreground)]">
        <a href={`${base}terms`} class="hover:text-[var(--foreground)] transition-colors">Terms</a>
        <a href={`${base}privacy`} class="hover:text-[var(--foreground)] transition-colors">Privacy</a>
        <a href={`${base}data-processing`} class="hover:text-[var(--foreground)] transition-colors">Data Processing</a>
        <a href="https://github.com/WellBeCC/ClipJot" target="_blank" rel="noopener noreferrer" aria-label="ClipJot on GitHub" class="hover:text-(--foreground) transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
        <a href="https://substack.com/@marvec" target="_blank" rel="noopener noreferrer" aria-label="Substack" class="hover:text-(--foreground) transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
          </svg>
        </a>
      </nav>

      <!-- Copyright -->
      <p class="text-xs text-[var(--muted-foreground)]">
        &copy; {year} ClipJot. All rights reserved.
      </p>
    </div>
  </div>
</footer>
